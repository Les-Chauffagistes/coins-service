datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider             = "prisma-client-py"
    interface            = "asyncio"
    recursive_type_depth = 5
}

model Currency {
    id          String   @id @default(uuid()) @db.Uuid
    name        String   @unique
    description String?
    claimRate   Int
    claimLimit  Int
    wallets     Wallet[]
    claims      Claim[]
    logs        Log[]

    @@map("currency")
}

model Wallet {
    currencyId String   @db.Uuid
    userId     Int
    balance    Int      @default(0)
    currency   Currency @relation(fields: [currencyId], references: [id])

    @@id([currencyId, userId])
    @@index([userId])
    @@map("wallet")
}

model Claim {
    currencyId  String    @db.Uuid
    userId      Int
    lastClaimAt DateTime
    currency    Currency  @relation(fields: [currencyId], references: [id])

    @@id([currencyId, userId])
    @@map("claims")
}

model Log {
    id         String   @id @default(uuid()) @db.Uuid
    userId     Int
    currencyId String   @db.Uuid
    amount     Int
    date       DateTime @default(now())
    reason     String?
    fromState  String?
    toState    String?
    currency   Currency @relation(fields: [currencyId], references: [id])

    @@index([userId, currencyId])
    @@map("log")
}
